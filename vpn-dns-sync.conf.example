# /etc/vpn-dns-sync.conf
# Loaded by vpn-dns-sync.sh

DO_API_TOKEN="dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The zone as registered in DigitalOcean DNS (the part after the last two dots)
DOMAIN="example.com"

# The subdomain portion — DO stores it without the zone suffix
# For ubuntu-server.home.internal.example.com, this is:
RECORD_NAME="ubuntu-server.home.internal"


# The VPN interface is set by the systemd instance name, e.g. vpn-dns-sync@tun0.
# Override STATE_FILE here only if you need a non-default path.
# STATE_FILE="/var/lib/vpn-dns-sync/tun0.last_ip"
